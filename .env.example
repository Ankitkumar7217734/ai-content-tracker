# Copy to .env and fill in values. Never commit .env to git.

# ── Supabase ────────────────────────────────────────────────────────────────
# Dashboard → your project → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

# Project URL (top of the API page)
SUPABASE_URL=https://xxxx.supabase.co

# anon public key (labeled "anon" / "publishable" on the API page)
# Used by the Streamlit app for user sign-up, sign-in, and RLS-protected queries.
SUPABASE_ANON_KEY=eyJ...

# service_role secret key (labeled "service_role" on the API page — click Reveal)
# Used ONLY by scheduled jobs (GitHub Actions). Never put this in Streamlit Cloud
# or the browser; it bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Resend (email) ──────────────────────────────────────────────────────────
# https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=you@yourdomain.com

# ── Web app (Next.js) ─────────────────────────────────────────────────────────
# Copy web/.env.local.example → web/.env.local (same SUPABASE_URL + ANON_KEY)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Encryption ──────────────────────────────────────────────────────────────
# Encrypts each user's OpenAI API key at rest. Generate once, keep secret:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
